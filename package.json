{
  "name": "extension-exporter",
  "version": "0.0.2",
  "type": "module",
  "description": "A CLI tool for exporting browser extensions",
  "bin": {
    "extension-exporter": "dist/index.mjs"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.mjs",
  "files": [
    "CHANGELOG.md",
    "SECURITY.md",
    "dist",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "format": "prettier -w . --list-different --cache",
    "lint": "eslint src --cache",
    "lint:fix": "eslint src --fix",
    "npm:patch": "changeset add",
    "npm:release": "changeset publish",
    "npm:version": "changeset version",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "archiver": "^7.0.1",
    "chalk": "^5.6.2",
    "glob": "^13.0.6",
    "p-limit": "^7.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@types/archiver": "^7.0.0",
    "@types/bun": "^1.3.13",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "prettier-plugin-pkg": "^0.22.1",
    "prettier-plugin-tailwindcss": "^0.7.3",
    "tsup": "^8.5.1",
    "typescript-eslint": "^8.59.0"
  }
}
